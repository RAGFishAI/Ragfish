#
# PostgreSQL DATABASE
#
DATABASE_TYPE=postgres          # Use 'postgres' for PostgreSQL 
DB_HOST=localhost               # Database host
DB_PORT=5432                    # Port for PostgreSQL
DB_DATABASE=your_database_name  # Name of your database
DB_USERNAME=your_username       # Database username
DB_PASSWORD=your_password       # Database password
DB_SSL_MODE=disable



#
#Keys
#
ACCESS_SECRET='!@#$%^&*()'
JWT_SECRET = '!@#$%^&*()'

#
#Sessios Keys
#
SESSION_KEY='ragfish'
SESSION_KEY1='ragfish1'
SESSION_KEY3='ragfish2'
CSRF_SECRET='secret123'
CHAT_SESSION_KEY='ragfishchat'
#
# Cors Allowed Origin
#
BASE_URL ='http://localhost:8080/'
DOMAIN_URL='http://localhost:8080/'
NODEBASE_URL='http://localhost:3003/'

ADMIN_PORT='8080'
#


#
#LANGUAGE PATH
#
LOCAL_LANGUAGE_PATH="locales/"

#
# System Settings
#
TIME_ZONE = "Asia/Kolkata"
DEFAULT_LANGUAGE = "English"
SPACE_DEFAULT = "yes"





#
#STORAGE TYPE(local,aws,azure,drive)
#
STORAGE_TYPE ='local'

# Copyrights
COPYRIGHTS ="Copyrights @ 2026 Piccosoft Lab"


# Qdrant Vector Database Configuration
QDRANT_URL=http://localhost:6333


# Embedding Model Configuration
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Server Configuration
PORT=3003
NODE_ENV=development

# File Upload Configuration
UPLOAD_DIR=./uploads

# CORS Configuration
CORS_ORIGIN=*
 